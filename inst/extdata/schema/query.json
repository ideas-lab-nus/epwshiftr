{
  "check": {
    "kind": "list"
  },
  "keys": {
    "type": "named",
    "must.include": ["index_node", "parameter"]
  },
  "fields": {
    "index_node": {
      "check": {
        "kind": "string"
      }
    },
    "parameter": {
      "check": {
        "kind": "list"
      },
      "keys": {
        "type": "named"
      },
      "rest": {
        "$ref": "#/$defs/parameter_entry"
      }
    }
  },
  "$defs": {
    "parameter_entry": {
      "any": [
        {
          "check": {
            "kind": "null"
          }
        },
        {
          "check": {
            "kind": "list"
          },
          "keys": {
            "type": "named",
            "subset.of": ["kind", "value", "negate", "encoded"],
            "must.include": "value"
          },
          "fields": {
            "kind": {
              "check": {
                "kind": "string"
              }
            },
            "value": {
              "any": [
                {
                  "check": {
                    "kind": "character",
                    "any.missing": false
                  }
                },
                {
                  "check": {
                    "kind": "logical",
                    "any.missing": false
                  }
                },
                {
                  "check": {
                    "kind": "integer",
                    "any.missing": false
                  }
                },
                {
                  "check": {
                    "kind": "numeric",
                    "any.missing": false
                  }
                },
                {
                  "check": {
                    "kind": "null"
                  }
                }
              ]
            },
            "negate": {
              "check": {
                "kind": "flag"
              }
            },
            "encoded": {
              "check": {
                "kind": "flag"
              }
            }
          }
        }
      ]
    }
  }
}
