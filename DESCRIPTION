Package: epwshiftr
Title: Create Future 'EnergyPlus' Weather Files using 'CMIP6' Data
Version: 0.1.4.9001
Authors@R: c(
    person(given = "Hongyuan",
           family = "Jia",
           role = c("aut", "cre"),
