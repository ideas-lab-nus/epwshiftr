\if{html}{\out{<a id="method-EsgQuery-count"></a>}}
\if{latex}{\out{\hypertarget{method-EsgQuery-count}{}}}
\subsection{Method \code{count()}}{
Send a query of facet counting and fetch the results
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{EsgQuery$count(facets = TRUE)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{facets}}{\code{NULL}, a flag or a character vector. There are three
options:
\itemize{
\item If \code{NULL} or \code{FALSE}, only the total number of matched records is
returned.
\item If \code{TRUE}, the value of \href{#method-EsgQuery-facets}{\code{$facets()}}
is used to limit the facets. If \verb{$facets()} returns \code{NULL}, only the
total count is returned. This is the default value.
\item If a character vector, it is used to limit the facets.
}}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
\itemize{
\item If \code{facets} equals \code{NULL} or \code{FALSE}, or \verb{$facets()} returns \code{NULL},
an integer.
\item Otherwise, a named list with the first element always being \code{total}
which is the total number of matched records. Other elements have
the same length as input facets and are all named integer vectors.
}
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
# get the total number of matched records
q$count(NULL) # or q$count(facets = FALSE)

# count records for specific facets
q$facets(c("activity_id", "source_id"))$count()

# same as above
q$count(facets = c("activity_id", "source_id"))
}
}
\if{html}{\out{</div>}}

}

}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-EsgQuery-collect"></a>}}
\if{latex}{\out{\hypertarget{method-EsgQuery-collect}{}}}
\subsection{Method \code{collect()}}{
Send the actual query and fetch the results

\verb{$collect()} sends the actual query to the ESGF search services.
By default it collects \strong{\code{type=Dataset}} results and returns an
\link{EsgResultDataset} object. If \code{type} is \code{"File"} or
\code{"Aggregation"}, it first collects matching Dataset results and then
collects child File or Aggregation results for those datasets.
The fields included depend on \code{fields} parameter.
However, the following fields are always included in the results:
\verb{access}, \verb{id}, \verb{index_node}, \verb{number_of_aggregations}, \verb{number_of_files}, \verb{size}, \verb{url}.
When a local \link{EsgDict} is available for the query project, \verb{$collect()}
also performs a warning-only dictionary check before sending the query.
Missing local dictionaries are ignored and never downloaded.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{EsgQuery$collect(
  all = FALSE,
  limit = TRUE,
  params = TRUE,
  type = "Dataset",
  fields = NULL,
  ...
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{all}}{Whether to collect all results despite of the value of
\code{offset}. Default: \code{FALSE}.}

\item{\code{limit}}{If \code{all = FALSE}, the maximum number of records to
collect in this request. If \code{all = TRUE}, the page size used
for each paginated request, not a total cap. When \code{all = TRUE}
and \code{limit = TRUE}, the current query \code{limit} value is used;
if \code{limit = FALSE}, the allowed maximum limit number
10000 is used. It can also be a positive
integer used as a temporary page size. Default: \code{TRUE}.}

\item{\code{params}}{Whether to include facet fields that have parameter
constraints explicitly set using \code{EsgQuery$project()},
\code{EsgQuery$activity_id()}, \code{EsgQuery$params()} and etc. in the
returned fields. For example, if you set \verb{$experiment_id("ssp585")},
the \code{experiment_id} field will be included in the results when
\code{params = TRUE}. Default: \code{TRUE}.}

\item{\code{type}}{Result type to collect. One of \code{"Dataset"}, \code{"File"},
or \code{"Aggregation"}. Default: \code{"Dataset"}.}

\item{\code{fields}}{Optional fields used only when \code{type} is \code{"File"} or
\code{"Aggregation"}. Dataset fields should be configured with
\verb{$fields()} before collecting.}

\item{\code{...}}{Arguments passed to \link{EsgResultDataset} child collection
when \code{type} is \code{"File"} or \code{"Aggregation"}, including the
\code{data_node} scope filter, child-query controls, and
\code{use_record_index_node}. File/Aggregation collection does not
use ESGF datetime search parameters; use \verb{$filter_time()} on the
returned result for time filtering.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
An \link{EsgResultDataset}, \link{EsgResultFile}, or
\link{EsgResultAggregation} object.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
# by default, all fields with constrains are included in the results
query <- esg_query()$experiment_id("ssp585")$frequency("1hr")$fields("source_id")
res1 <- query$collect()
res1$fields

# set `params` to `FALSE` to exclude them
query$collect(params = FALSE)$fields

# collect all matched records with `query$limit()` records per query
res2 <- query$collect(all = TRUE, limit = TRUE)
identical(query$count(), res2$count())

# same as above, but collect all matched records with max allowed
# record limit per query
res3 <- query$collect(all = TRUE, limit = FALSE)
identical(res2$count(), res3$count())

# same as above, but collect all matched records with specified limit
# per query
res4 <- query$collect(all = TRUE, limit = 30)
identical(res2$count(), res4$count())
}
}
\if{html}{\out{</div>}}

}

}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-EsgQuery-state"></a>}}
\if{latex}{\out{\hypertarget{method-EsgQuery-state}{}}}
\subsection{Method \code{state()}}{
Get the current query state.

\verb{$state()} returns a read-only snapshot containing the current index
node and the current parameter state.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{EsgQuery$state(name = NULL, null = FALSE)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{name}}{A character vector of parameter names to include, or
\code{NULL} to include all parameters.}

\item{\code{null}}{If \code{TRUE}, include parameters whose current value is
\code{NULL}. Otherwise, omit unset parameters.}
}
\if{html}{\out{</div>}}
}
